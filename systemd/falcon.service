[Unit]
Description=Falcon Auto-Commit Engine
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=elixpo_workstation
WorkingDirectory=/home/elixpo_workstation/falcon
ExecStart=/home/elixpo_workstation/falcon/venv/bin/python3 -m falcon
StandardOutput=append:/home/elixpo_workstation/falcon/falcon.log
StandardError=append:/home/elixpo_workstation/falcon/falcon.log
Environment=HOME=/home/elixpo_workstation
Environment=GIT_AUTHOR_NAME=lixiorg
Environment=GIT_AUTHOR_EMAIL=lixiorg@users.noreply.github.com
Environment=GIT_COMMITTER_NAME=lixiorg
Environment=GIT_COMMITTER_EMAIL=lixiorg@users.noreply.github.com

[Install]
WantedBy=multi-user.target
